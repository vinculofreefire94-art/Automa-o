# ═══════════════════════════════════════════════
#   BTC SIGNAL BOT — Environment Configuration
# ═══════════════════════════════════════════════

# ── Telegram ──────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here          # Canal ou grupo (-100...)
TELEGRAM_ADMIN_ID=your_personal_id_here     # Alertas de erro e status

# ── Exchange (Binance por padrão) ─────────────
EXCHANGE=binance
API_KEY=                                    # Opcional — só para dados privados
API_SECRET=                                 # Opcional

# ── Pares monitorados ─────────────────────────
PAIRS=BTC/USDT,BTC/EUR,BTC/USDC

# ── Timeframes (análise multi-TF) ─────────────
TIMEFRAMES=1h,4h,1d

# ── Scheduler (cron-like) ─────────────────────
SCAN_INTERVAL_MINUTES=15                    # Frequência de scan

# ── Filtros de Sinal ──────────────────────────
MIN_SIGNAL_STRENGTH=2                       # 1=fraco 2=médio 3=forte
SEND_ALL_SIGNALS=true                       # false = só força ≥ 3

# ── Chart Settings ────────────────────────────
CHART_STYLE=dark                            # dark | pro | neon
CHART_CANDLES=100                           # Número de candles no gráfico

# ── Modo ──────────────────────────────────────
DEBUG=false
DRY_RUN=true                               # Não envia ordens reais
